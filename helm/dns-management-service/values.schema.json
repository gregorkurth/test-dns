{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "image",
    "service",
    "ingress",
    "otel",
    "debug",
    "resources",
    "securityContext"
  ],
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "image": {
      "type": "object",
      "required": ["repository", "pullPolicy"],
      "properties": {
        "repository": {
          "type": "string",
          "minLength": 1
        },
        "tag": {
          "type": "string"
        },
        "digest": {
          "type": "string",
          "pattern": "^$|^sha256:[a-f0-9]{64}$"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      }
    },
    "service": {
      "type": "object",
      "required": ["type", "port", "targetPort"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "targetPort": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "nodePort": {
          "type": ["integer", "null"],
          "minimum": 30000,
          "maximum": 32767
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": { "const": "NodePort" }
            }
          },
          "then": {
            "required": ["nodePort"],
            "properties": {
              "nodePort": {
                "type": "integer",
                "minimum": 30000,
                "maximum": 32767
              }
            }
          }
        }
      ]
    },
    "ingress": {
      "type": "object",
      "required": ["enabled", "className", "hostname", "path", "pathType", "tls"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "className": {
          "type": "string"
        },
        "hostname": {
          "type": "string"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "pathType": {
          "type": "string",
          "enum": ["Prefix", "Exact", "ImplementationSpecific"]
        },
        "annotations": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "boolean"]
          }
        },
        "tls": {
          "type": "object",
          "required": ["enabled", "secretName"],
          "properties": {
            "enabled": { "type": "boolean" },
            "secretName": { "type": "string" }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "enabled": { "const": true }
            }
          },
          "then": {
            "properties": {
              "className": { "minLength": 1 },
              "hostname": { "minLength": 1 }
            }
          }
        },
        {
          "if": {
            "properties": {
              "enabled": { "const": true },
              "tls": {
                "properties": {
                  "enabled": { "const": true }
                }
              }
            }
          },
          "then": {
            "properties": {
              "tls": {
                "properties": {
                  "secretName": { "minLength": 1 }
                }
              }
            }
          }
        }
      ]
    },
    "otel": {
      "type": "object",
      "required": ["serviceName", "mode", "endpoint"],
      "properties": {
        "serviceName": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": ["local", "clickhouse"]
        },
        "endpoint": {
          "type": "string",
          "minLength": 1
        },
        "exportTimeoutMs": {
          "type": "string",
          "pattern": "^[0-9]+$"
        }
      }
    },
    "testOperator": {
      "type": "object",
      "required": ["enabled", "image", "schedule", "telemetry", "rbac"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "image": {
          "type": "object",
          "required": ["repository", "tag", "pullPolicy"],
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string", "minLength": 1 },
            "digest": {
              "type": "string",
              "pattern": "^$|^sha256:[a-f0-9]{64}$"
            },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          }
        },
        "schedule": {
          "type": "object",
          "required": ["intervalMinutes", "maxRuntimeSeconds", "nonOverlapPolicy"],
          "properties": {
            "intervalMinutes": { "type": "integer", "minimum": 1, "maximum": 1440 },
            "maxRuntimeSeconds": { "type": "integer", "minimum": 30, "maximum": 7200 },
            "nonOverlapPolicy": {
              "type": "string",
              "enum": ["skip_if_active_run"]
            }
          }
        },
        "telemetry": {
          "type": "object",
          "required": ["mode", "endpoint", "spoolDirectory", "retryPolicy"],
          "properties": {
            "mode": { "type": "string", "enum": ["local", "clickhouse"] },
            "endpoint": { "type": "string", "minLength": 1 },
            "spoolDirectory": { "type": "string", "minLength": 1 },
            "retryPolicy": { "type": "string", "minLength": 1 }
          }
        },
        "rbac": {
          "type": "object",
          "required": ["create", "serviceAccountName", "clusterRoleName"],
          "properties": {
            "create": { "type": "boolean" },
            "serviceAccountName": { "type": "string", "minLength": 1 },
            "clusterRoleName": { "type": "string", "minLength": 1 }
          }
        },
        "resources": {
          "type": "object",
          "required": ["requests", "limits"],
          "properties": {
            "requests": {
              "type": "object",
              "required": ["cpu", "memory"],
              "properties": {
                "cpu": { "type": "string", "minLength": 1 },
                "memory": { "type": "string", "minLength": 1 }
              }
            },
            "limits": {
              "type": "object",
              "required": ["cpu", "memory"],
              "properties": {
                "cpu": { "type": "string", "minLength": 1 },
                "memory": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        "securityContext": {
          "type": "object",
          "required": ["allowPrivilegeEscalation", "readOnlyRootFilesystem", "runAsNonRoot"],
          "properties": {
            "allowPrivilegeEscalation": { "type": "boolean" },
            "readOnlyRootFilesystem": { "type": "boolean" },
            "runAsNonRoot": { "type": "boolean" }
          }
        }
      }
    },
    "debug": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      }
    },
    "resources": {
      "type": "object",
      "required": ["requests", "limits"],
      "properties": {
        "requests": {
          "type": "object",
          "required": ["cpu", "memory"],
          "properties": {
            "cpu": { "type": "string", "minLength": 1 },
            "memory": { "type": "string", "minLength": 1 }
          }
        },
        "limits": {
          "type": "object",
          "required": ["cpu", "memory"],
          "properties": {
            "cpu": { "type": "string", "minLength": 1 },
            "memory": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "securityContext": {
      "type": "object",
      "required": ["pod", "container"],
      "properties": {
        "pod": {
          "type": "object",
          "required": ["runAsNonRoot"],
          "properties": {
            "runAsNonRoot": { "type": "boolean" }
          }
        },
        "container": {
          "type": "object",
          "required": ["allowPrivilegeEscalation", "readOnlyRootFilesystem"],
          "properties": {
            "allowPrivilegeEscalation": { "type": "boolean" },
            "readOnlyRootFilesystem": { "type": "boolean" }
          }
        }
      }
    }
  }
}
