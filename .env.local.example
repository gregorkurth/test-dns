# OBJ-12 Auth – Session Secret (mind. 32 Zeichen, zufällig generiert)
# Generieren: openssl rand -base64 48
OBJ12_SESSION_SECRET=REPLACE_WITH_RANDOM_SECRET_MIN_32_CHARS

# OBJ-12 Auth – Modus: local | oidc | hybrid
OBJ12_AUTH_MODE=local

# OBJ-12 Auth – Lokale User (optional, überschreibt config/users.local.json)
# OBJ12_LOCAL_USERS_JSON=[{"username":"admin","role":"admin","password":"..."}]

# OBJ-12 Auth – Pfad zum User-File (optional, Standard: config/users.local.json)
# OBJ12_LOCAL_USERS_FILE=/pfad/zu/users.json

# OBJ-12 Auth – Session-Gültigkeit
# OBJ12_SESSION_TTL_HOURS=8

# OBJ-27 Docs – URL zum MkDocs-Dokumentationsportal (Standard: http://localhost:8081)
# NEXT_PUBLIC_DOCS_URL=http://localhost:8081
