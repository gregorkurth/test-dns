        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "editorType": "sql",
          "format": 1,
          "query": "SELECT count() AS security_events FROM otel_security_events WHERE Timestamp >= $__fromTime",
          "queryType": "sql",
          "refId": "A"
        }
      ],
      "title": "Security Events",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-otel"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 4,
      "options": {
        "footer": {
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "editorType": "sql",
          "format": 1,
          "query": "SELECT Timestamp, ServiceName, Body, TraceId FROM otel_security_events WHERE Timestamp >= $__fromTime ORDER BY Timestamp DESC LIMIT 50",
          "queryType": "sql",
          "refId": "A"
        }
      ],
      "title": "Recent Security Events",
      "type": "table"
    },
    {
      "datasource": {
        "type": "grafana-clickhouse-datasource",
        "uid": "clickhouse-otel"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 5,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "editorType": "sql",
          "format": 1,
          "query": "SELECT toStartOfMinute(TimeUnix) AS t, MetricName, sum(Value) AS total FROM otel_metrics WHERE MetricName IN ('dns_zone_generation_total', 'otel_export_failures_total', 'operator_reconcile_total') AND TimeUnix >= $__fromTime GROUP BY t, MetricName ORDER BY t",
          "queryType": "sql",
          "refId": "A"
        }
      ],
      "title": "Core Service Metrics",
      "type": "timeseries"
