OTEL_SERVICE_NAME=dns-management-service
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.monitoring.svc.cluster.local:4318
OTEL_LOG_LEVEL=info
OTEL_RESOURCE_ATTRIBUTES=service.namespace=dns,service.version=0.1.0,deployment.environment=local
OBSERVABILITY_MODE=local
OBSERVABILITY_SPOOL_DIR=/var/lib/otel/spool
OBSERVABILITY_QUEUE_DIR=/var/lib/otel/queue
OBSERVABILITY_SECURITY_STREAM=enabled
OBSERVABILITY_GRAFANA_DASHBOARD_VERSION=dns-observability-v1
